{
  "name": "xnet-backend-radius-pro",
  "version": "1.0.0",
  "description": "",
  "main": "server.js",
  "scripts": {
    "test": "jest",
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "nodemon",
    "typeorm:generate": "typeorm migration:generate -n",
    "typeorm:run": "typeorm migration:run",
    "typeorm:revert": "typeorm migration:revert",
    "typeorm": "typeorm",
    "typeorm:entity:generate": "npm run typeorm -- entity:create",
    "generate-entities": "npm run typeorm -- -d src/db/config.ts entity:create /src/entities",
    "generate:entities": "typeorm-model-generator -h localhost -d radius -u radius -x password -e mysql -o ./outputEntities",
    "docker:build": "docker build --no-cache -t xnet-backend-radius-pro .",
    "docker:run": "docker run -p 3000:3000 --env-file .env xnet-backend-radius-pro",
    "docker:dev": "docker-compose -f docker-compose.dev.yml up",
    "docker:dev:stop": "docker-compose -f docker-compose.dev.yml down",
    "docker:prod": "docker-compose -f docker-compose.yml up",
    "docker:stop": "docker-compose -f docker-compose.yml down",
    "docker:logs": "docker-compose logs -f",
    "docker:clean": "docker system prune -f"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "amqplib": "^0.10.5",
    "axios": "^1.9.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "express-status-monitor": "^1.3.4",
    "express-validator": "^7.2.1",
    "express-winston": "^4.2.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.2",
    "mysql2": "^3.12.0",
    "node-cron": "^3.0.3",
    "node-routeros": "^1.6.8",
    "ping": "^0.4.4",
    "radius": "^1.1.4",
    "redis": "^4.7.0",
    "socket.io": "^4.8.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "ws": "^8.18.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.7",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/express-rate-limit": "^5.1.3",
    "@types/express-status-monitor": "^1.3.3",
    "@types/express-winston": "^3.0.4",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.15.32",
    "@types/node-cron": "^3.0.11",
    "@types/ping": "^0.4.4",
    "@types/radius": "^0.0.33",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/ws": "^8.18.0",
    "jest": "^27.0.6",
    "nodemon": "^3.1.9",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typeorm": "^0.3.20"
  }
