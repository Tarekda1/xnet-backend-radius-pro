## Backend environment (Node/Express)
## Copy to `.env` and adjust values.
##
## Windows (PowerShell):
##   Copy-Item env.example .env

# Server
NODE_ENV=development
PORT=3000
LOG_FORMAT=json

# JWT
JWT_SECRET=change_me
REFRESH_TOKEN_SECRET=change_me

# RADIUS shared secret (for packet decode)
RADIUS_SECRET=change_me

# Database (TypeORM)
DB_HOST=host.docker.internal
DB_PORT=3306
DB_USERNAME=radius
DB_PASSWORD=password
DB_NAME=radius
DB_LOGGING_ENABLED=false

# Redis
# Prefer REDIS_URL, otherwise REDIS_HOST/REDIS_PORT
REDIS_URL=redis://localhost:6379
# REDIS_HOST=localhost
# REDIS_PORT=6379

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_MANAGEMENT_URL=http://localhost:15672

# Online session staleness (seconds). When NAS does not send Interim-Update, open
# radacct rows with acctupdatetime=NULL are still counted as online (acctstoptime IS NULL).
ONLINE_SESSION_STALE_SECONDS=300
# "Active now" KPI window (recent accounting); idle sessions remain in the online list.
ONLINE_SESSION_ACTIVE_SECONDS=120

# When set, periodically: (1) set active→expired where expires_at < NOW(), (2) disconnect open radacct rows.
# Example: every 5 minutes. Requires NAS rows + secrets for Disconnect-Request fallback; MikroTik API optional.
# EXPIRY_DISCONNECT_CRON=*/5 * * * *
# EXPIRY_DISCONNECT_BATCH=100
# Optional: run one pass ~5s after startup (good for testing; cron still runs on schedule).
# EXPIRY_DISCONNECT_RUN_ON_STARTUP=1
# Align MySQL time_zone with expires_at semantics if status flip seems late/early.

# HTTP tuning (optional)
AXIOS_TIMEOUT_MS=10000
HTTP_KEEPALIVE_TIMEOUT_MS=65000
HTTP_HEADERS_TIMEOUT_MS=70000
HTTP_REQUEST_TIMEOUT_MS=60000

# MikroTik (optional)
MIKROTIK_IP=172.9.16.2
MIKROTIK_USERNAME=apiuser
MIKROTIK_PASSWORD=123456
MIKROTIK_API_PORT=8728
MIKROTIK_MONITOR_INTERFACE=ether6-OUT

# Flow logs / ClickHouse (optional)
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DB=flow_logs
CLICKHOUSE_USER=flow
CLICKHOUSE_PASSWORD=flowpass
FLOW_LOG_TEMPLATES=false
FLOW_LOG_UNMAPPED=false
FLOW_ROUTER_ID=

# WhatsApp sending (disabled by default)
WHATSAPP_ENABLED=false
WHATSAPP_PROVIDER=cloud
WHATSAPP_OVERRIDE_TO=

# Meta WhatsApp Cloud API (only if WHATSAPP_PROVIDER=cloud)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TEMPLATE_NAME=payment_confirmation
WHATSAPP_TEMPLATE_LANGUAGE_CODE=en_US

# Twilio (only if WHATSAPP_PROVIDER=twilio)
# Get Account SID + Auth Token from https://console.twilio.com (regenerate token if you see error 20003 / 401)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Optional (recommended): API Key auth instead of primary Auth Token
# Create at Console → Account → API keys & tokens → Create API key
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
# WhatsApp sender: your approved Twilio WhatsApp number (with or without whatsapp: prefix)
# Example: whatsapp:+14195572878
TWILIO_WHATSAPP_FROM=
# Optional: use a Messaging Service instead of TWILIO_WHATSAPP_FROM (must include WhatsApp sender)
TWILIO_MESSAGING_SERVICE_SID=
# Twilio Content API template SID for outbound WhatsApp templates
# Payment confirmation (sent when invoice is marked paid)
TWILIO_CONTENT_SID=
# Payment reminder (required for Send reminder / dunning) — separate template from payment
TWILIO_CONTENT_SID_REMINDER=
# Reminder variable mode: structured ({{1}}..{{5}}) or full_body (single {{1}} = entire message)
TWILIO_REMINDER_CONTENT_MODE=structured
# Reminder template body (create in Twilio Content → WhatsApp):
# Hi {{1}}, this is a payment reminder for Invoice #{{2}} (Billing month: {{3}}), amount: ${{4}}. Status: {{5}}. Thank you.
TWILIO_CONTENT_VARIABLES_JSON=
TWILIO_STATUS_CALLBACK_URL=

# Observability / compose helpers
PROM_REMOTE_WRITE_URL=
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
# Windows Docker Desktop uses a named pipe, not /var/run/docker.sock
# DOCKER_SOCK=//./pipe/docker_engine

